# Copie este arquivo para .env e preencha os valores reais
# O arquivo .env NUNCA deve ser commitado no git

# Servidor
PORT=8080
ENVIRONMENT=production

# JWT — use uma senha longa e aleatória em produção
JWT_SECRET=troque-por-uma-senha-muito-longa-e-aleatoria

# Banco de dados
DB_PATH=./clubbix.db

# Credenciais do admin (acesso ao painel administrativo)
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=TroqueIssoAgora@2026
ADMIN_CPF=00000000000

# Conta demo (opcional — deixe vazio para não criar)
DEMO_EMAIL=demo@seudominio.com
DEMO_PASSWORD=TroqueIssoTambem@2026
DEMO_CPF=00000000000

# Gateway de pagamento AppMax (opcional)
APPMAX_TOKEN=
APPMAX_ORDER_URL=https://api.appmax.com.br/api/v3/order
